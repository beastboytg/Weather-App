<%- include("partials/header.ejs") %>
    <main class="main">
        <section class="search-bar-section">
            <form class="input-form" action="/weather" method="GET" autocomplete="off">
                <div class="search-wrapper">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5"
                        stroke="currentColor" class="search-icon">
                        <path stroke-linecap="round" stroke-linejoin="round"
                            d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
                    </svg>

                    <input type="text" class="search-bar" placeholder="Search a city" name="location"
                        value="<%= locals.city || '' %>">

                    <div class="suggestions hidden">
                        <div class="city choice">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5"
                                stroke="currentColor" class="location-icon">
                                <path stroke-linecap="round" stroke-linejoin="round"
                                    d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                                <path stroke-linecap="round" stroke-linejoin="round"
                                    d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
                            </svg>

                            London
                        </div>
                        <div class="city choice">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5"
                                stroke="currentColor" class="location-icon">
                                <path stroke-linecap="round" stroke-linejoin="round"
                                    d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                                <path stroke-linecap="round" stroke-linejoin="round"
                                    d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
                            </svg>

                            New York
                        </div>
                        <div class="city choice">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5"
                                stroke="currentColor" class="location-icon">
                                <path stroke-linecap="round" stroke-linejoin="round"
                                    d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                                <path stroke-linecap="round" stroke-linejoin="round"
                                    d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
                            </svg>

                            Tokyo
                        </div>
                        <div class="city choice">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5"
                                stroke="currentColor" class="location-icon">
                                <path stroke-linecap="round" stroke-linejoin="round"
                                    d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                                <path stroke-linecap="round" stroke-linejoin="round"
                                    d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
                            </svg>

                            Dubai
                        </div>
                        <div class="city choice">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5"
                                stroke="currentColor" class="location-icon">
                                <path stroke-linecap="round" stroke-linejoin="round"
                                    d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                                <path stroke-linecap="round" stroke-linejoin="round"
                                    d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
                            </svg>

                            Mumbai
                        </div>
                        <div class="city choice">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5"
                                stroke="currentColor" class="location-icon">
                                <path stroke-linecap="round" stroke-linejoin="round"
                                    d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                                <path stroke-linecap="round" stroke-linejoin="round"
                                    d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
                            </svg>

                            Sydney
                        </div>
                    </div>
                </div>

                <% if (!locals.city) { %>
                    <svg xmlns="http://w3.org" viewBox="0 0 100 100" width="100%" height="100%" class="weather-emoji">
                        <defs>
                            <!-- Sun Gradient -->
                            <linearGradient id="sunGrad" x1="0%" y1="0%" x2="100%" y2="100%">
                                <stop offset="0%" stop-color="#FFF066" />
                                <stop offset="100%" stop-color="#FF9900" />
                            </linearGradient>

                            <!-- Cloud Gradient -->
                            <linearGradient id="cloudGrad" x1="0%" y1="0%" x2="0%" y2="100%">
                                <stop offset="0%" stop-color="#FFFFFF" />
                                <stop offset="100%" stop-color="#D2E4F0" />
                            </linearGradient>

                            <!-- Cloud Shadow -->
                            <filter id="shadow" x="-20%" y="-20%" width="140%" height="140%">
                                <feDropShadow dx="0" dy="3" stdDeviation="3" flood-color="#002244"
                                    flood-opacity="0.15" />
                            </filter>
                        </defs>

                        <!-- Sun Background Glow -->
                        <circle cx="38" cy="38" r="22" fill="#FFCC00" opacity="0.2" filter="blur(4px)" />

                        <!-- Sun -->
                        <g>
                            <!-- Sun Body -->
                            <circle cx="38" cy="38" r="18" fill="url(#sunGrad)" />

                            <!-- Sun Rays -->
                            <g stroke="url(#sunGrad)" stroke-width="3.5" stroke-linecap="round">
                                <line x1="38" y1="12" x2="38" y2="4" />
                                <line x1="38" y1="64" x2="38" y2="56" />
                                <line x1="12" y1="38" x2="4" y2="38" />
                                <line x1="64" y1="38" x2="56" y2="38" />
                                <line x1="19.6" y1="19.6" x2="14" y2="14" />
                                <line x1="56.4" y1="56.4" x2="62" y2="62" />
                                <line x1="19.6" y1="56.4" x2="14" y2="62" />
                                <line x1="56.4" y1="19.6" x2="62" y2="14" />
                            </g>
                        </g>

                        <!-- Cloud -->
                        <path d="M 25 70 
                    A 14 14 0 0 1 34 44 
                    A 19 19 0 0 1 68 38 
                    A 15 15 0 0 1 84 52 
                    A 13 13 0 0 1 78 78 
                    Z" fill="url(#cloudGrad)" filter="url(#shadow)" />
                    </svg>

                    <p class="text">Search a city to see weather</p>

                    <div class="option-list">
                        <div class="options choice">
                            <p>London</p>
                        </div>
                        <div class="options choice">
                            <p>New York</p>
                        </div>
                        <div class="options choice">
                            <p>Tokyo</p>
                        </div>
                        <div class="options choice">
                            <p>Dubai</p>
                        </div>
                        <div class="options choice">
                            <p>Mumbai</p>
                        </div>
                        <div class="options choice">
                            <p>Sydney</p>
                        </div>
                    </div>
                    <% } else { %>
                        <div class="weather-container">
                            <div class="temp-container">
                                <div class="location-container">
                                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
                                        stroke-width="1.5" stroke="currentColor" class="location-icon">
                                        <path stroke-linecap="round" stroke-linejoin="round"
                                            d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                                        <path stroke-linecap="round" stroke-linejoin="round"
                                            d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
                                    </svg>
                                    <p>
                                        <%= locals.city %>, <%= locals.weather.location.country %>
                                    </p>
                                </div>
                                <h1><span class="temp-number">
                                        <%= Math.floor(locals.weather.current.temp_c) %>
                                    </span><span class="degree-symbol">°C</span></h1>
                                <p class="weather-type">
                                    <% if ( weatherType===`Thunder`) { %>
                                        Thunder Storm
                                        <% } else if( weatherType===`Sunny`){ %>
                                            <% if( locals.weather.current.is_day===1){ %>
                                                Sunny
                                                <% } else { %>
                                                    Clear Sky
                                                    <% } %>
                                                        <% } else { %>
                                                            <%= weatherType %>
                                                                <% } %>
                                </p>
                                <p class="feels-like">Feels like <%= locals.weather.current.feelslike_c %>°C</p>
                                <p class="lats-longs">
                                    <%= locals.weather.location.lat %> · <%= locals.weather.location.lon %>
                                </p>
                            </div>
                            <div class="uv-and-weather-emoji">
                                <div class="uv">
                                    <script>window.uv = <%= locals.weather.current.uv %> ; </script>
                                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
                                        stroke-width="1.5" stroke="currentColor" class="uv-icon">
                                        <path stroke-linecap="round" stroke-linejoin="round"
                                            d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z" />
                                    </svg>
                                    <p> UV <%= Math.floor(locals.weather.current.uv) %> ·</p>
                                    <% if (locals.weather.current.uv>= 0 && locals.weather.current.uv<= 2) { %>
                                            <p>Low</p>
                                            <% } else if (locals.weather.current.uv>= 3 && locals.weather.current.uv
                                                <=5) { %>
                                                    <p>Moderate</p>
                                                    <% } else if (locals.weather.current.uv>= 6 &&
                                                        locals.weather.current.uv <= 7) { %>
                                                            <p>High</p>
                                                            <% } else if (locals.weather.current.uv>= 8 &&
                                                                locals.weather.current.uv <= 10) { %>
                                                                    <p>Very High</p>
                                                                    <% } else { %>
                                                                        <p>Extreme</p>
                                                                        <% } %>
                                </div>
                                <div class="weather-sticker">
                                    <% if (weatherType==="Raining" ) { %>
                                        <svg width="100" height="100" viewBox="0 0 220 220"
                                            xmlns="http://www.w3.org/2000/svg">

                                            <defs>

                                                <!-- Darker Rain Cloud -->
                                                <linearGradient id="cloudGrad" x1="0%" y1="0%" x2="0%" y2="100%">
                                                    <stop offset="0%" stop-color="#EEF4FB" />
                                                    <stop offset="100%" stop-color="#B8C7DB" />
                                                </linearGradient>

                                                <!-- Shadow -->
                                                <filter id="shadow">
                                                    <feDropShadow dx="0" dy="4" stdDeviation="4" flood-color="#001A44"
                                                        flood-opacity="0.15" />
                                                </filter>

                                            </defs>

                                            <!-- Floating Group -->
                                            <g>

                                                <!-- Gentle Float -->
                                                <animateTransform attributeName="transform" type="translate"
                                                    values="0 0;0 -4;0 0" dur="4s" repeatCount="indefinite" />

                                                <!-- Cloud -->
                                                <path d="
                                                    M65 115
                                                    C65 95, 85 88, 98 95
                                                    C102 75, 128 72, 140 88
                                                    C160 88, 172 100, 172 115
                                                    C185 118, 188 135, 172 142
                                                    H78
                                                    C58 142, 50 122, 65 115Z
                                                    " fill="url(#cloudGrad)" filter="url(#shadow)" />

                                                <!-- Rain -->
                                                <g stroke="#4EA3FF" stroke-width="3" stroke-linecap="round">

                                                    <!-- Drop 1 -->
                                                    <line x1="82" y1="157" x2="78" y2="174">

                                                        <animateTransform attributeName="transform" type="translate"
                                                            values="0 -10;0 10" dur="0.9s" repeatCount="indefinite" />

                                                        <animate attributeName="opacity" values="0.15;1;0.15" dur="0.9s"
                                                            repeatCount="indefinite" />
                                                    </line>

                                                    <!-- Drop 2 -->
                                                    <line x1="105" y1="157" x2="101" y2="174">

                                                        <animateTransform attributeName="transform" type="translate"
                                                            values="0 -8;0 12" dur="0.8s" begin="0.2s"
                                                            repeatCount="indefinite" />

                                                        <animate attributeName="opacity" values="0.15;1;0.15" dur="0.8s"
                                                            begin="0.2s" repeatCount="indefinite" />
                                                    </line>

                                                    <!-- Drop 3 -->
                                                    <line x1="128" y1="157" x2="124" y2="174">

                                                        <animateTransform attributeName="transform" type="translate"
                                                            values="0 -10;0 10" dur="1s" begin="0.4s"
                                                            repeatCount="indefinite" />

                                                        <animate attributeName="opacity" values="0.15;1;0.15" dur="1s"
                                                            begin="0.4s" repeatCount="indefinite" />
                                                    </line>

                                                    <!-- Drop 4 -->
                                                    <line x1="150" y1="157" x2="146" y2="174">

                                                        <animateTransform attributeName="transform" type="translate"
                                                            values="0 -8;0 12" dur="0.85s" begin="0.1s"
                                                            repeatCount="indefinite" />

                                                        <animate attributeName="opacity" values="0.15;1;0.15"
                                                            dur="0.85s" begin="0.1s" repeatCount="indefinite" />
                                                    </line>

                                                </g>

                                            </g>

                                        </svg>
                                        <% } else if (weatherType==="Sunny" ) { %>
                                            <% if (weather.current.is_day==1) { %>
                                                <svg width="100" height="100" viewBox="0 0 220 220"
                                                    xmlns="http://www.w3.org/2000/svg">
                                                    <defs>
                                                        <radialGradient id="sunGradient">
                                                            <stop offset="0%" stop-color="#FFF9A8" />
                                                            <stop offset="100%" stop-color="#FDB813" />
                                                        </radialGradient>

                                                        <filter id="glow">
                                                            <feGaussianBlur stdDeviation="4" result="coloredBlur" />
                                                            <feMerge>
                                                                <feMergeNode in="coloredBlur" />
                                                                <feMergeNode in="SourceGraphic" />
                                                            </feMerge>
                                                        </filter>
                                                    </defs>

                                                    <!-- Floating Sun -->
                                                    <g filter="url(#glow)">
                                                        <animateTransform attributeName="transform" type="translate"
                                                            values="0 0;0 -6;0 0" dur="4s" repeatCount="indefinite" />

                                                        <!-- Rotating Rays -->
                                                        <g>

                                                            <g stroke="#FDB813" stroke-width="6" stroke-linecap="round">
                                                                <line x1="110" y1="20" x2="110" y2="45" />
                                                                <line x1="110" y1="175" x2="110" y2="200" />

                                                                <line x1="20" y1="110" x2="45" y2="110" />
                                                                <line x1="175" y1="110" x2="200" y2="110" />

                                                                <line x1="45" y1="45" x2="62" y2="62" />
                                                                <line x1="158" y1="158" x2="175" y2="175" />

                                                                <line x1="175" y1="45" x2="158" y2="62" />
                                                                <line x1="45" y1="175" x2="62" y2="158" />
                                                            </g>
                                                        </g>

                                                        <!-- Sun Glow -->
                                                        <circle cx="110" cy="110" r="55" fill="#FFD54A" opacity="0.25">

                                                            <animate attributeName="r" values="55;62;55" dur="3s"
                                                                repeatCount="indefinite" />
                                                        </circle>

                                                        <!-- Sun Body -->
                                                        <circle cx="110" cy="110" r="45" fill="url(#sunGradient)">

                                                            <animate attributeName="r" values="45;48;45" dur="3s"
                                                                repeatCount="indefinite" />
                                                        </circle>

                                                    </g>
                                                </svg>
                                                <% } else { %>
                                                    <svg width="100" height="100" viewBox="0 0 220 220"
                                                        xmlns="http://www.w3.org/2000/svg">

                                                        <defs>

                                                            <!-- Moon -->
                                                            <radialGradient id="moonGradient">
                                                                <stop offset="0%" stop-color="#FFF5B8" />
                                                                <stop offset="100%" stop-color="#FFE08A" />
                                                            </radialGradient>

                                                            <!-- Moon Glow -->
                                                            <radialGradient id="moonGlow">
                                                                <stop offset="0%" stop-color="#FFF5B8"
                                                                    stop-opacity="0.35" />
                                                                <stop offset="100%" stop-color="#FFF5B8"
                                                                    stop-opacity="0" />
                                                            </radialGradient>

                                                            <!-- Cloud -->
                                                            <linearGradient id="cloudGradient" x1="0%" y1="0%" x2="0%"
                                                                y2="100%">
                                                                <stop offset="0%" stop-color="#FFFFFF" />
                                                                <stop offset="100%" stop-color="#D9E5F5" />
                                                            </linearGradient>

                                                            <!-- Soft Shadow -->
                                                            <filter id="shadow">
                                                                <feDropShadow dx="0" dy="4" stdDeviation="4"
                                                                    flood-color="#001A4D" flood-opacity="0.15" />
                                                            </filter>

                                                        </defs>

                                                        <!-- Float Animation -->
                                                        <g>
                                                            <animateTransform attributeName="transform" type="translate"
                                                                values="0 0;0 -5;0 0" dur="4s"
                                                                repeatCount="indefinite" />

                                                            <!-- Moon Glow -->
                                                            <circle cx="130" cy="80" r="55" fill="url(#moonGlow)">
                                                                <animate attributeName="r" values="55;62;55" dur="4s"
                                                                    repeatCount="indefinite" />
                                                            </circle>

                                                            <!-- Moon -->
                                                            <circle cx="130" cy="80" r="38" fill="url(#moonGradient)" />

                                                            <!-- Moon Craters -->
                                                            <circle cx="112" cy="62" r="5" fill="#F8DA80"
                                                                opacity="0.35" />
                                                            <circle cx="148" cy="70" r="7" fill="#F8DA80"
                                                                opacity="0.35" />
                                                            <circle cx="120" cy="96" r="8" fill="#F8DA80"
                                                                opacity="0.35" />
                                                            <circle cx="154" cy="98" r="6" fill="#F8DA80"
                                                                opacity="0.35" />

                                                            <!-- Cloud Front -->
                                                            <g filter="url(#shadow)">

                                                                <path d="
                                                        M45 135
                                                        A22 22 0 0 1 70 108
                                                        A38 38 0 0 1 110 92
                                                        A30 30 0 0 1 145 105
                                                        A24 24 0 0 1 175 120
                                                        A18 18 0 0 1 188 145

                                                        L188 160
                                                        L45 160
                                                        Z
                                                        " fill="url(#cloudGradient)" />

                                                                <!-- Cloud bumps -->
                                                                <circle cx="65" cy="130" r="24"
                                                                    fill="url(#cloudGradient)" />
                                                                <circle cx="105" cy="115" r="38"
                                                                    fill="url(#cloudGradient)" />
                                                                <circle cx="145" cy="125" r="30"
                                                                    fill="url(#cloudGradient)" />
                                                                <circle cx="178" cy="135" r="24"
                                                                    fill="url(#cloudGradient)" />

                                                            </g>

                                                        </g>

                                                    </svg>
                                                    <% } %>
                                                        <% } else if (weatherType==="Thunder" ) {%>
                                                            <svg width="100" height="100" viewBox="0 0 220 220"
                                                                xmlns="http://www.w3.org/2000/svg">

                                                                <defs>

                                                                    <!-- Storm Cloud -->
                                                                    <linearGradient id="cloudGrad" x1="0%" y1="0%"
                                                                        x2="0%" y2="100%">
                                                                        <stop offset="0%" stop-color="#7C879C" />
                                                                        <stop offset="100%" stop-color="#2F3B52" />
                                                                    </linearGradient>

                                                                    <!-- Lightning -->
                                                                    <linearGradient id="boltGrad" x1="0%" y1="0%"
                                                                        x2="0%" y2="100%">
                                                                        <stop offset="0%" stop-color="#FFE45E" />
                                                                        <stop offset="100%" stop-color="#FFC400" />
                                                                    </linearGradient>

                                                                    <!-- Shadow -->
                                                                    <filter id="shadow">
                                                                        <feDropShadow dx="0" dy="4" stdDeviation="4"
                                                                            flood-color="#000000"
                                                                            flood-opacity="0.18" />
                                                                    </filter>

                                                                    <!-- Lightning Glow -->
                                                                    <filter id="boltGlow">
                                                                        <feDropShadow dx="0" dy="0" stdDeviation="5"
                                                                            flood-color="#FFD93D" flood-opacity="0.8" />
                                                                    </filter>

                                                                </defs>

                                                                <!-- Floating Group -->
                                                                <g>

                                                                    <animateTransform attributeName="transform"
                                                                        type="translate" values="0 0;0 -4;0 0" dur="4s"
                                                                        repeatCount="indefinite" />

                                                                    <!-- Cloud -->
                                                                    <path d="
                                                    M65 115
                                                    C65 95, 85 88, 98 95
                                                    C102 75, 128 72, 140 88
                                                    C160 88, 172 100, 172 115
                                                    C185 118, 188 135, 172 142
                                                    H78
                                                    C58 142, 50 122, 65 115Z
                                                    " fill="url(#cloudGrad)" filter="url(#shadow)" />

                                                                    <!-- Lightning -->
                                                                    <path d="
                                                    M112 138
                                                    L98 170
                                                    H112
                                                    L100 198
                                                    L135 155
                                                    H120
                                                    L132 138
                                                    Z
                                                    " fill="url(#boltGrad)" filter="url(#boltGlow)">
                                                                        <animate attributeName="opacity"
                                                                            values="1;0.65;1;0.4;1" dur="2s"
                                                                            repeatCount="indefinite" />
                                                                    </path>

                                                                    <!-- Rain -->
                                                                    <g stroke="#4EA3FF" stroke-width="3"
                                                                        stroke-linecap="round">

                                                                        <!-- Left Outer -->
                                                                        <line x1="82" y1="157" x2="78" y2="174">

                                                                            <animateTransform attributeName="transform"
                                                                                type="translate" values="0 -10;0 10"
                                                                                dur="0.9s" repeatCount="indefinite" />

                                                                            <animate attributeName="opacity"
                                                                                values="0.15;1;0.15" dur="0.9s"
                                                                                repeatCount="indefinite" />
                                                                        </line>

                                                                        <!-- Left Inner -->
                                                                        <line x1="95" y1="157" x2="91" y2="174">

                                                                            <animateTransform attributeName="transform"
                                                                                type="translate" values="0 -8;0 12"
                                                                                dur="0.8s" begin="0.2s"
                                                                                repeatCount="indefinite" />

                                                                            <animate attributeName="opacity"
                                                                                values="0.15;1;0.15" dur="0.8s"
                                                                                begin="0.2s" repeatCount="indefinite" />
                                                                        </line>

                                                                        <!-- Right Inner -->
                                                                        <line x1="145" y1="157" x2="141" y2="174">

                                                                            <animateTransform attributeName="transform"
                                                                                type="translate" values="0 -8;0 12"
                                                                                dur="0.85s" begin="0.1s"
                                                                                repeatCount="indefinite" />

                                                                            <animate attributeName="opacity"
                                                                                values="0.15;1;0.15" dur="0.85s"
                                                                                begin="0.1s" repeatCount="indefinite" />
                                                                        </line>

                                                                        <!-- Right Outer -->
                                                                        <line x1="158" y1="157" x2="154" y2="174">

                                                                            <animateTransform attributeName="transform"
                                                                                type="translate" values="0 -10;0 10"
                                                                                dur="1s" begin="0.3s"
                                                                                repeatCount="indefinite" />

                                                                            <animate attributeName="opacity"
                                                                                values="0.15;1;0.15" dur="1s"
                                                                                begin="0.3s" repeatCount="indefinite" />
                                                                        </line>

                                                                    </g>

                                                                </g>

                                                            </svg>
                                                            <% } else if (weatherType==="Cloudy" ) { %>
                                                                <svg width="100" height="100" viewBox="0 0 220 220"
                                                                    xmlns="http://www.w3.org/2000/svg">

                                                                    <defs>

